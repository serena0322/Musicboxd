<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Sfondo leggermente trasparente, grigio-nero -->
    <solid android:color="@color/black" /> <!-- ~80% opacità -->

    <!-- Bordi più soft (grigio chiaro ma non bianco) -->
    <stroke
        android:width="1dp"
        android:color="#66D0D0D0" /> <!-- grigio chiaro semi-trasparente -->

    <!-- Angoli arrotondati -->
    <corners android:radius="24dp" />
</shape>




