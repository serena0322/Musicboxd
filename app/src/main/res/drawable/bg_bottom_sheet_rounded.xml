<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sfondo scuro con angoli arrotondati solo sopra -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/scrollView" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>

    <!-- Bordo sottile bianco sopra + laterali -->
    <item android:left="0dp" android:right="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="@android:color/white"/>
            <solid android:color="@android:color/transparent" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>

    <!-- Maschera per coprire il bordo in basso -->
    <item android:top="675dp"> <!-- Cambia questo valore se necessario -->
        <shape android:shape="rectangle">
            <solid android:color="@color/scrollView" />
        </shape>
    </item>

</layer-list>



