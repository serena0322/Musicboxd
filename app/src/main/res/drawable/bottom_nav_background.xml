<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Sfondo: grigio molto scuro con leggera trasparenza -->
    <solid android:color="#262626" /> <!-- tonalità coerente con @color/scrollView -->

    <!-- Bordi superiori più morbidi -->
    <corners
        android:radius="14dp" />

    <!-- Bordo sottile e leggero per definizione -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" /> <!-- bianco 20% opaco -->
</shape>

