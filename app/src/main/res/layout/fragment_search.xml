<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!--Titolo-->
    <TextView
        android:id="@+id/Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="105dp"
        android:layout_marginTop="47dp"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/poppinsbold"
        android:text="Search"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <!-- Barra di ricerca -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/Title"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/search_background"
        android:queryHint="Cerca su Musicboxd..."
        app:iconifiedByDefault="false" /> <!-- sfondo trasparente per il campo -->

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:layout_below="@id/searchView"
        android:background="@color/scrollView">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/browseBy"
                style="@style/ClickableListItem"
                android:padding="10dp"
                android:text="Browse by"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/releaseDate"
                style="@style/ClickableListItem"
                android:text="Release date" />

            <TextView
                android:id="@+id/genreCountryLanguage"
                style="@style/ClickableListItem"
                android:text="Genre, country or language" />

            <TextView
                android:id="@+id/service"
                style="@style/ClickableListItem"
                android:text="Service" />

            <TextView
                android:id="@+id/mostPopular"
                style="@style/ClickableListItem"
                android:text="Most popular" />

            <TextView
                android:id="@+id/highestRated"
                style="@style/ClickableListItem"
                android:text="Highest rated" />

            <TextView
                android:id="@+id/mostAnticipated"
                style="@style/ClickableListItem"
                android:text="Most anticipated" />

            <TextView
                android:id="@+id/top250"
                style="@style/ClickableListItem"
                android:text="Top 250 narrative features" />

            <TextView
                android:id="@+id/featuredLists"
                style="@style/ClickableListItem"
                android:text="Featured lists" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#333" />

        </LinearLayout>
    </ScrollView>


</RelativeLayout>

