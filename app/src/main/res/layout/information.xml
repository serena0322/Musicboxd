<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:fitsSystemWindows="true"
        android:paddingTop="?attr/actionBarSize"
        app:layout_constrainedWidth="true"
        app:layout_constrainedHeight="true">


    <!-- Barrier: serve a posizionare in modo robusto ciò che sta sotto cover+info -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/infoBottomBarrier"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="infoCover,date" />

        <!-- COVER: percentuale + rapporto 1:1 -->
        <ImageView
            android:id="@+id/infoCover"
            android:layout_marginTop="32dp"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="Cover Image"
            android:scaleType="centerCrop"
            app:layout_constraintWidth_percent="0.36"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- TITOLO -->
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppinsbold"
            app:layout_constrainedWidth="true"
            app:layout_constraintStart_toEndOf="@id/infoCover"
            app:layout_constraintTop_toTopOf="@id/infoCover"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ARTISTA -->
        <TextView
            android:id="@+id/artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Artist"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="italic"
            android:fontFamily="@font/poppinsmedium"
            android:letterSpacing="0.01"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ALBUM -->
        <TextView
            android:id="@+id/album"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Album"
            android:textColor="@color/light_gray"
            android:textSize="14sp"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintStart_toStartOf="@id/artist"
            app:layout_constraintTop_toBottomOf="@id/artist"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- DATA -->
        <TextView
            android:id="@+id/date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Date"
            android:textColor="@color/light_gray"
            android:textSize="14sp"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintStart_toStartOf="@id/album"
            app:layout_constraintTop_toBottomOf="@id/album"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- GENERE -->
        <TextView
            android:id="@+id/genre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Genre"
            android:textColor="@color/light_gray"
            android:textSize="14sp"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoBottomBarrier"
            app:layout_constraintEnd_toStartOf="@+id/duration" />

        <!-- DURATA (allineata alla baseline di GENERE) -->
        <TextView
            android:id="@+id/duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Duration"
            android:textColor="@color/light_gray"
            android:textSize="14sp"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintBaseline_toBaselineOf="@id/genre"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- PULSANTI: catena orizzontale -->
        <Button
            android:id="@+id/play"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Riproduci Anteprima"
            android:textSize="12sp"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/home"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/genre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/playlist"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <Button
            android:id="@+id/playlist"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Aggiungi alla Playlist"
            android:textSize="12sp"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/home"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="@id/play"
            app:layout_constraintBottom_toBottomOf="@id/play"
            app:layout_constraintStart_toEndOf="@id/play"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TITOLO SEZIONE RATINGS -->
        <TextView
            android:id="@+id/Ratings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="RATINGS"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppinsbold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/play"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CONTAINER RATING + STARS -->
        <LinearLayout
            android:id="@+id/ratingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="@id/ratingHistogram"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp">

            <!-- NUMERO RATING (centrato sulle stelle) -->
            <TextView
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/poppinsbold"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <!-- STELLE, ASCIUGATE SU UNA RIGA -->
            <TextView
                android:id="@+id/ratingStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★★★"
                android:textColor="@color/home"
                android:textSize="16sp"
                android:fontFamily="@font/poppinsmedium"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- ISTOGRAMMA A SINISTRA -->
        <LinearLayout
            android:id="@+id/ratingHistogram"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:weightSum="10"
            app:layout_constraintTop_toBottomOf="@id/Ratings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ratingContainer">

        <View android:id="@+id/bar_0_5" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_1_0" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_1_5" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_2_0" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_2_5" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_3_0" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_3_5" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_4_0" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_4_5" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>
        <View android:id="@+id/bar_5_0" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:background="@drawable/rating_bar_background"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
